#!name=擷取 SAP Rules
#!desc=修改 CCMS 請求讓 shopee_network-ios 回傳完整 config，擷取 network_interceptor_sap_rules

[Script]
# [SAP]擷取所有shopee回應 = type=http-response, pattern=^https://.*shopee\.(tw|io|com), script-path=https://raw.githubusercontent.com/LienCF/surge_modules/refs/heads/master/shopee_find_sap.js, requires-body=true, max-size=1048576

[MITM]
hostname = %APPEND% *.shopee.tw, *.shopee.io, *.shopee.com
