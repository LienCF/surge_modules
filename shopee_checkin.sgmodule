#!name=蝦皮每日自動簽到
#!desc=每天早上自動簽到 + 開蝦幣寶箱 + 開免運寶箱。必須先手動簽到一次。 v20231013.1
#[蝦皮]每日簽到 = type=cron, cronexp="16 0 * * *", script-path=https://gginin.de/surge/scripts/shopee_checkin.js, wake-system=1, timeout=5

[Script]
[蝦皮]更新token = type=cron, cronexp="10 */8 * * *", script-path=https://gginin.de/surge/scripts/shopee_update_token.js, wake-system=1, timeout=10
[蝦皮]蝦幣寶箱 = type=cron, cronexp="17 0 * * *", script-path=https://raw.githubusercontent.com/LienCF/surge_modules/refs/heads/master/shopee_coin_lucky_draw.js, wake-system=1, timeout=10
[蝦皮]免運寶箱 = type=cron, cronexp="17 0 * * *", script-path=https://gginin.de/surge/scripts/shopee_shipping_lucky_draw.js, wake-system=1, timeout=10
[蝦皮]取得簽到資訊 = type=http-request, pattern=^https:\/\/games-dailycheckin\.shopee\.tw\/mkt\/coins\/api\/v2\/checkin_new$, script-path=https://raw.githubusercontent.com/LienCF/surge_modules/refs/heads/master/shopee_get_checkin.js, requires-body=true
# [蝦皮]取得DFP = type=http-request, pattern=^https:\/\/idgame\.shopee\.tw\/api\/luckydraw\/, script-path=https://raw.githubusercontent.com/LienCF/surge_modules/refs/heads/master/shopee_get_dfp.js, requires-body=false
# [蝦皮]擷取msdk回應 = type=http-response, pattern=^https:\/\/msdk\.shopee\.tw\/, script-path=https://raw.githubusercontent.com/LienCF/surge_modules/refs/heads/master/shopee_get_msdk.js, requires-body=true
# [蝦皮]擷取config回應 = type=http-response, pattern=^https:\/\/.*shopee\.tw\/api\/v[0-9]+\/(configs|global_config), script-path=https://raw.githubusercontent.com/LienCF/surge_modules/refs/heads/master/shopee_get_msdk.js, requires-body=true, max-size=524288
[蝦皮]擷取dynconfig回應 = type=http-response, pattern=^https:\/\/.*dynamic-config-api\.shopee\.tw\/, script-path=https://raw.githubusercontent.com/LienCF/surge_modules/refs/heads/master/shopee_get_msdk.js, requires-body=true, max-size=524288
# DISABLED: 缺少 anti-fraud headers
#[蝦皮]每日簽到 = type=cron, cronexp="16 0 * * *", script-path=https://raw.githubusercontent.com/LienCF/surge_modules/refs/heads/master/shopee_checkin.js, wake-system=1, timeout=5

[MITM]
hostname = %APPEND% games-dailycheckin.shopee.tw, idgame.shopee.tw, msdk.shopee.tw, *.shopee.tw
